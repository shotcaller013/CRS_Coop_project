APP_NAME="CRS Cooperative"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://your-droplet-ip-or-domain

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crs_coop
DB_USERNAME=crs_user
DB_PASSWORD=your_db_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=your-droplet-ip-or-domain
SESSION_DOMAIN=your-droplet-ip-or-domain
